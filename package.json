{
  "name": "alpha-brain",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["packages/*", "apps/*"],
  "packageManager": "bun@1.3.4",
  "overrides": {
    "prosemirror-model": "1.25.9"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@alpha-brain/web",
    "dev:api": "turbo run dev --filter=@alpha-brain/api",
    "dev:backend": "convex dev --cwd packages/convex",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "turbo": "2.10.0",
    "typescript": "^5"
  }
}
